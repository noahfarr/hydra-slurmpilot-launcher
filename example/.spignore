# Gitignore-style patterns. Anything matched here is excluded from the
# upload to the cluster. See README of the slurmpilot fork for details.

# Python bytecode and caches.
__pycache__/
*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Local virtualenvs.
.venv/
venv/

# Hydra / experiment outputs that should not ship to the cluster.
outputs/
multirun/
wandb/

# Editor / OS noise.
.idea/
.vscode/
.DS_Store
